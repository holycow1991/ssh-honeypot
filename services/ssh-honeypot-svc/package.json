{
	"name": "ssh-honeypot-svc",
	"version": "1.0.14",
	"description": "SSH honeypot service",
	"author": "Edwin Hernandez",
	"repository": "edwinhern/express-typescript-2024",
	"license": "MIT",
	"main": "index.ts",
	"private": true,
	"scripts": {
		"build": "tsc && tsup",
		"start:dev": "kill $(lsof -ti :2222) 2>/dev/null || echo \"No process on port 2222\" && node --import=tsx --watch src/index.ts",
		"start:prod": "node dist/index.js",
		"migrate": "node --import=tsx src/infrastructure/persistence/migrations/runMigrations.ts",
		"migrate:up": "pnpm migrate",
		"check": "biome check --write",
		"test": "vitest run",
		"test:cov": "vitest run --coverage"
	},
	"dependencies": {
		"dotenv": "17.2.1",
		"pino": "9.9.0",
		"pg": "8.13.1",
		"ssh2": "^1.17.0",
		"zod": "3.25.76"
	},
	"devDependencies": {
		"@biomejs/biome": "2.1.4",
		"@types/pg": "8.11.10",
		"@types/ssh2": "^1.15.5",
		"@vitest/coverage-v8": "3.2.4",
		"pino-pretty": "13.1.1",
		"tsup": "8.5.0",
		"tsx": "4.20.4",
		"typescript": "5.9.2",
		"vite-tsconfig-paths": "5.1.4",
		"vitest": "3.2.4"
	},
	"tsup": {
		"entry": [
			"src/index.ts"
		],
		"outDir": "dist",
		"format": [
			"esm",
			"cjs"
		],
		"target": "es2020",
		"sourcemap": true,
		"clean": true,
		"dts": true,
		"splitting": false,
		"skipNodeModulesBundle": true
	},
	"packageManager": "pnpm@10.14.0"
}
